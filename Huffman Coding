#include <iostream>
#include <vector>
#include <queue>
#include <string>

using namespace std;

struct Node {
    char data;
    int freq;
    Node *left, *right;
    // Constructor for cleaner node creation
    Node(char d, int f, Node* l = nullptr, Node* r = nullptr) 
        : data(d), freq(f), left(l), right(r) {}
};

// Comparison object for the priority queue (Min-Heap)
struct Compare {
    bool operator()(Node* l, Node* r) { return l->freq > r->freq; }
};

void printCodes(Node* root, string code) {
    if (!root) return;
    if (!root->left && !root->right) cout << root->data << ": " << code << endl;
    printCodes(root->left, code + "0");
    printCodes(root->right, code + "1");
}

int main() {
    int n;
    cout << "Enter number of characters: "; cin >> n;

    priority_queue<Node*, vector<Node*>, Compare> pq;
    
    cout << "Enter char and frequency:\n";
    for (int i = 0; i < n; i++) {
        char c; int f;
        cin >> c >> f;
        pq.push(new Node(c, f));
    }

    while (pq.size() > 1) {
        Node *left = pq.top(); pq.pop();
        Node *right = pq.top(); pq.pop();
        pq.push(new Node('$', left->freq + right->freq, left, right));
    }

    cout << "\nHuffman Codes:\n";
    printCodes(pq.top(), "");
    return 0;
}
